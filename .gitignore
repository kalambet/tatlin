# Swift / SPM
.build/
.swiftpm/
*.xcodeproj
*.xcworkspace
# The menubar app's Xcode project IS tracked; un-ignore the project and the
# embedded workspace, then re-exclude user-specific state below.
!/Tatlin/Tatlin.xcodeproj
!/Tatlin/Tatlin.xcodeproj/project.xcworkspace
/Tatlin/Tatlin.xcodeproj/xcuserdata/
/Tatlin/Tatlin.xcodeproj/project.xcworkspace/xcuserdata/
# Package.resolved IS committed — pins the fragile pre-1.0 MLX/FluidAudio versions
# to the verified working set.

# Xcode
DerivedData/
.xcode-build/
*.xcuserstate
xcuserdata/

# macOS
.DS_Store

# Tatlin local data — never commit models, recordings, or eval audio
# (anchored to repo root so it does NOT match Sources/TatlinKit/Models/)
/Models/
/eval/audio/
*.wav
*.caf
*.mlmodelc
*.safetensors

# Dev-only tooling artifacts
tools/eval-golden/.venv/
tools/eval-golden/__pycache__/

# Coverage artifacts
*.profraw
